# This domain is a static React app. Prevent Plesk's Passenger handler from
# treating client-side routes such as /behavior as server applications.
PassengerEnabled off

Options -MultiViews
RewriteEngine On

# Keep real files and directories (assets, favicon, .well-known) untouched.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Let React Router handle application routes.
RewriteRule ^ index.html [L]
